{
  "entities": {
    "Task": {
      "title": "Task",
      "description": "A task to be completed",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["completed", "in-progress", "overdue", "pending", "waste"] },
        "time": { "type": "string" },
        "isLazy": { "type": "boolean" },
        "date": { "type": "string" },
        "category": { "type": "string", "enum": ["life", "study", "work"] },
        "groupId": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["id", "title", "status", "time", "userId"]
    },
    "FocusSession": {
      "title": "FocusSession",
      "description": "A focus session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "duration": { "type": "number" },
        "date": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["id", "duration", "date", "userId"]
    },
    "RecordBlock": {
      "title": "RecordBlock",
      "description": "A block of content in a record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "image"] },
        "content": { "type": "string" }
      },
      "required": ["id", "type", "content"]
    },
    "Record": {
      "title": "Record",
      "description": "An inspiration record or summary",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "blocks": { "type": "array", "items": { "$ref": "RecordBlock" } },
        "title": { "type": "string" },
        "date": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "link": { "type": "string" },
        "isPinned": { "type": "boolean" },
        "type": { "type": "string", "enum": ["record", "summary"] },
        "userId": { "type": "string" }
      },
      "required": ["id", "blocks", "date", "type", "userId"]
    },
    "Prompt": {
      "title": "Prompt",
      "description": "An AI prompt",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "tag": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "userId": { "type": "string" }
      },
      "required": ["id", "title", "content", "tag", "userId"]
    },
    "Chore": {
      "title": "Chore",
      "description": "A daily chore",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "completed": { "type": "boolean" },
        "userId": { "type": "string" }
      },
      "required": ["id", "text", "completed", "userId"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "consecutiveDays": { "type": "number" },
        "lastCompletionDate": { "type": "string" },
        "lazyTitle": { "type": "string" },
        "aiActiveTab": { "type": "string" }
      }
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "UserProfile" },
      "description": "User profile and settings"
    },
    "users/{userId}/tasks/{taskId}": {
      "schema": { "$ref": "Task" },
      "description": "Tasks for a user"
    },
    "users/{userId}/focusSessions/{sessionId}": {
      "schema": { "$ref": "FocusSession" },
      "description": "Focus sessions for a user"
    },
    "users/{userId}/records/{recordId}": {
      "schema": { "$ref": "Record" },
      "description": "Inspiration records and summaries for a user"
    },
    "users/{userId}/prompts/{promptId}": {
      "schema": { "$ref": "Prompt" },
      "description": "AI prompts for a user"
    },
    "users/{userId}/chores/{choreId}": {
      "schema": { "$ref": "Chore" },
      "description": "Daily chores for a user"
    }
  }
}
